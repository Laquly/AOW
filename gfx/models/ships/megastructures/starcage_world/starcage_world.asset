entity = {#护盾
	name = "starcage_world_shield_entity"
	pdxmesh = "bunker_ring_white_shield_mesh"
	game_data = {
		uv_animation_direction = { 0.5 0.25 }
		uv_animation_speed = 1
	}
	scale = 1.5
}
entity = {
	name = "starcage_world_01_entity"
	pdxmesh = "ring_world_ration_mesh"
	default_state = idle
	attach = { root = starcage_world_shield_entity }
	state = { name = "idle" animation = "idle" animation_speed = 8 looping = yes }
}
entity = {
	name = "starcage_world_02_construction_entity"
	pdxmesh = "ring_world_ration_mesh"
